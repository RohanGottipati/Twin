{
  "database": "techto",
  "indexes": [
    {
      "collectionName": "documents",
      "name": "techto-search",
      "type": "search",
      "definition": {
        "mappings": {
          "dynamic": false,
          "fields": {
            "title": { "type": "string" },
            "body": { "type": "string" },
            "tags": { "type": "string" },
            "documentType": { "type": "token" }
          }
        }
      }
    },
    {
      "collectionName": "document_chunks",
      "name": "techto-memory-vector",
      "type": "vectorSearch",
      "definition": {
        "fields": [
          {
            "type": "vector",
            "path": "embedding",
            "numDimensions": 1536,
            "similarity": "cosine"
          },
          {
            "type": "filter",
            "path": "documentId"
          }
        ]
      }
    }
  ],
  "notes": [
    "Create these in Atlas UI: Database → Search → Create Index, or via Atlas Admin API.",
    "Core TechTO search falls back to regex when Atlas Search is unavailable.",
    "Vector index is reserved for FreeSolo / memory embeddings; not required for the fixture demo."
  ]
}
